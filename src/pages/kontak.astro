---
import Layout from '../layouts/Layout.astro';
import TopNavBar from '../components/TopNavBar.astro';
import Footer from '../components/Footer.astro';
import FloatingChat from '../components/FloatingChat.astro';
import ContactForm from '../components/ContactForm';

const contactInfo = [
  { icon: 'location_on', label: 'Alamat', value: 'Jl. Sunan Muria No.12, Kudus, Jawa Tengah 59316' },
  { icon: 'call', label: 'Telepon / WhatsApp', value: '+62 812-3456-7890' },
  { icon: 'mail', label: 'Email', value: 'info@kudusflorist.com' },
  { icon: 'schedule', label: 'Jam Operasional', value: 'Senin – Sabtu, 08:00 – 20:00\nMinggu, 09:00 – 17:00' },
];
---

<Layout title="Kontak - Kudus Florist">
  <TopNavBar />

  <main class="pt-20 min-h-screen bg-background">
    <!-- Hero Mini -->
    <div class="relative bg-primary py-24 overflow-hidden">
      <div class="absolute inset-0 opacity-10">
        <span class="material-symbols-outlined text-[35rem] text-white absolute -right-10 -top-10">call</span>
      </div>
      <div class="max-w-container-max mx-auto px-margin-desktop relative z-10">
        <div class="flex items-center gap-2 font-label-md text-on-primary/60 mb-4">
          <a href="/" class="hover:text-on-primary transition-colors">Beranda</a>
          <span class="material-symbols-outlined text-sm">chevron_right</span>
          <span class="text-on-primary">Kontak</span>
        </div>
        <h1 class="font-display-lg text-headline-lg md:text-display-lg text-on-primary mb-4">Hubungi Kami</h1>
        <p class="font-body-lg text-on-primary/80 max-w-xl">
          Ada pertanyaan, pesanan khusus, atau ingin konsultasi? Kami siap membantu Anda.
        </p>
      </div>
    </div>

    <!-- Main Content -->
    <section class="py-20">
      <div class="max-w-container-max mx-auto px-margin-desktop">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

          <!-- Form -->
          <div>
            <ContactForm client:load />
          </div>

          <!-- Info -->
          <div class="space-y-8">
            <div>
              <h2 class="font-headline-sm text-headline-sm text-on-background mb-6">Informasi Kontak</h2>
              <ul class="space-y-5">
                {contactInfo.map((item) => (
                  <li class="flex items-start gap-4">
                    <div class="w-11 h-11 bg-primary/10 rounded-xl flex items-center justify-center shrink-0">
                      <span class="material-symbols-outlined text-primary">{item.icon}</span>
                    </div>
                    <div>
                      <p class="font-label-md text-on-surface-variant text-xs uppercase tracking-widest mb-1">{item.label}</p>
                      <p class="font-body-md text-on-background whitespace-pre-line">{item.value}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Social -->
            <div>
              <p class="font-label-md text-on-surface-variant text-xs uppercase tracking-widest mb-4">Ikuti Kami</p>
              <div class="flex gap-3">
                <a href="#" class="w-11 h-11 bg-primary/10 rounded-xl flex items-center justify-center hover:bg-primary hover:text-on-primary text-primary transition-all group">
                  <span class="material-symbols-outlined text-xl">camera</span>
                </a>
                <a href="#" class="w-11 h-11 bg-primary/10 rounded-xl flex items-center justify-center hover:bg-primary hover:text-on-primary text-primary transition-all group">
                  <span class="material-symbols-outlined text-xl">share</span>
                </a>
                <a href="#" class="w-11 h-11 bg-primary/10 rounded-xl flex items-center justify-center hover:bg-primary hover:text-on-primary text-primary transition-all group">
                  <span class="material-symbols-outlined text-xl">chat</span>
                </a>
              </div>
            </div>

            <!-- Maps Embed -->
            <div>
              <p class="font-label-md text-on-surface-variant text-xs uppercase tracking-widest mb-4">Lokasi Kami</p>
              <div class="rounded-2xl overflow-hidden shadow-md border border-outline-variant h-64">
                <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d63325.21244375247!2d110.80459869453123!3d-6.804117999999999!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e70f9d5b3b3b3b3%3A0x7b3b3b3b3b3b3b3b!2sKudus%2C%20Jawa%20Tengah!5e0!3m2!1sid!2sid!4v1620000000000!5m2!1sid!2sid"
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Lokasi Kudus Florist di Kudus, Jawa Tengah"
                ></iframe>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>

  <Footer />
  <FloatingChat />
</Layout>
