---
---
<footer class="bg-primary w-full py-12 border-t border-white/10 mb-0">
  <div class="max-w-container-max mx-auto px-margin-desktop grid grid-cols-1 md:grid-cols-3 gap-gutter items-start">
    <div class="space-y-4">
      <div class="font-headline-sm text-headline-sm font-bold text-on-primary">Kudus Florist</div>
      <p class="font-body-md text-on-primary/80 max-w-xs">
        Sentuhan magis dari setiap kelopak bunga untuk melengkapi kebahagiaan Anda.
      </p>
      <div class="flex gap-4">
        <button class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-all opacity-80 hover:opacity-100">
          <span class="material-symbols-outlined text-on-primary text-xl">share</span>
        </button>
        <button class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-all opacity-80 hover:opacity-100">
          <span class="material-symbols-outlined text-on-primary text-xl">camera</span>
        </button>
        <button class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-all opacity-80 hover:opacity-100">
          <span class="material-symbols-outlined text-on-primary text-xl">chat</span>
        </button>
      </div>
    </div>

    <div class="space-y-4">
      <h4 class="font-label-md text-on-primary font-bold uppercase tracking-widest text-xs">Informasi</h4>
      <ul class="space-y-2">
        <li><a class="font-label-md text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/tentang-kami">Tentang Kami</a></li>
        <li><a class="font-label-md text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/koleksi">Koleksi Bunga</a></li>
        <li><a class="font-label-md text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/kontak">Kontak Kami</a></li>
        <li><a class="font-label-md text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/checkout">Checkout</a></li>
      </ul>
    </div>

    <div class="space-y-4">
      <h4 class="font-label-md text-on-primary font-bold uppercase tracking-widest text-xs">Lokasi &amp; Kontak</h4>
      <ul class="space-y-3">
        <li class="flex items-start gap-3">
          <span class="material-symbols-outlined text-on-primary/80">location_on</span>
          <span class="font-body-md text-on-primary/80">Jl. Sunan Muria No.12, Kudus, Jawa Tengah</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="material-symbols-outlined text-on-primary/80">call</span>
          <span class="font-body-md text-on-primary/80">+62 812-3456-7890</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="material-symbols-outlined text-on-primary/80">mail</span>
          <span class="font-body-md text-on-primary/80">info@kudusflorist.com</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="material-symbols-outlined text-on-primary/80">schedule</span>
          <span class="font-body-md text-on-primary/80">Senin – Sabtu, 08:00 – 20:00</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="max-w-container-max mx-auto px-margin-desktop mt-12 pt-8 border-t border-white/5 text-center">
    <p class="font-label-md text-on-primary/60">
      © 2024 Kudus Florist. Seni Merangkai Keindahan.
    </p>
  </div>
</footer>
